{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./thinkclear-app/src/*"]
    },
    /* ← ADD THESE: */
    "typeRoots": ["./types", "thinkclear-app/node_modules/@types"]
    /* ↑ so TS picks up your heic-convert.d.ts shim first */
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts" /* ← ensure your shim is loaded */,
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["thinkclear-app/node_modules"]
}
